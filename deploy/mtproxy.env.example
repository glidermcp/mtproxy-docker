# Required: public IPv4 or hostname for Telegram clients.
MTPROXY_PUBLIC_HOST=life.wearbrands.vip

# Required when MTPROXY_PUBLIC_HOST is a hostname instead of an IPv4 address.
# MTPROXY_NAT_PUBLIC_IP=203.0.113.10

# Required: raw 32-hex MTProxy secret.
# Printed Telegram links will add dd by default.
# MTPROXY_SECRET=0123456789abcdef0123456789abcdef

# Optional: disable padded client links and print raw secrets instead.
# MTPROXY_PADDED_LINKS=0

# Optional: proxy tag from @MTProxybot for sponsored placement.
# If the sponsor target should be @wear_brands_spain, configure that in
# @MTProxybot first and paste the returned tag here.
# MTPROXY_SPONSORED_TAG=

# Optional runtime tuning.
# MTPROXY_PORT=443
# MTPROXY_STATS_PORT=8888
# MTPROXY_WORKERS=1
